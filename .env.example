# ═══════════════════════════════════════════════════════════
#  South Wagga Warriors FC — Environment Config
#  Copy this to .env and fill in your values
#  NEVER commit .env to git
# ═══════════════════════════════════════════════════════════

# ── POSTGRES ────────────────────────────────────────────────
POSTGRES_DB=warriors
POSTGRES_USER=warriors
POSTGRES_PASSWORD=change_me_strong_password

# ── DIRECTUS ────────────────────────────────────────────────
DIRECTUS_SECRET=change_me_random_64_char_string
DIRECTUS_ADMIN_EMAIL=andy@southwagga.com.au
DIRECTUS_ADMIN_PASSWORD=change_me_admin_password
DIRECTUS_PUBLIC_URL=https://admin.southwagga.com.au
# Static token for Astro to read content (create in Directus after first login)
DIRECTUS_STATIC_TOKEN=

# ── SITE ────────────────────────────────────────────────────
PUBLIC_SITE_URL=https://southwagga.com.au

# ── EMAIL (EmuTel SMTP) ─────────────────────────────────────
EMAIL_FROM=noreply@southwagga.com.au
SMTP_HOST=mail.southwagga.com.au
SMTP_PORT=587
SMTP_USER=noreply@southwagga.com.au
SMTP_PASSWORD=

# ── DRIBL ───────────────────────────────────────────────────
# Find your club ID by running: docker compose run scraper node scraper.js --discover
DRIBL_CLUB_ID=
# Leave blank until Dribl API access is obtained
DRIBL_API_TOKEN=

# ── SOCIAL APIs ─────────────────────────────────────────────
# Instagram Basic Display API (get from developers.facebook.com)
INSTAGRAM_ACCESS_TOKEN=
INSTAGRAM_USER_ID=

# YouTube Data API (get from console.cloud.google.com)
YOUTUBE_API_KEY=
YOUTUBE_CHANNEL_ID=

# Facebook Page (just the page name, no API needed for embed)
FACEBOOK_PAGE_URL=https://www.facebook.com/SouthWaggaWarriorsFC

# ── N8N ─────────────────────────────────────────────────────
N8N_HOST=n8n.southwagga.com.au
N8N_WEBHOOK_URL=https://n8n.southwagga.com.au
N8N_USER=admin
N8N_PASSWORD=change_me_n8n_password
