---
// src/pages/coaching/index.astro
import Base from '../../layouts/Base.astro';

const PIN = import.meta.env.PUBLIC_COACHING_PIN || process.env.PUBLIC_COACHING_PIN || '';
---
<Base title="Coaches Hub" description="South Wagga Warriors FC coaching portal for session plans and resources.">

  <!-- PIN gate — client-side, good enough for club coaching resources -->
  {PIN && (
    <div id="pin-gate" class="gate">
      <div class="gate-box card">
        <div class="gate-logo">⚽</div>
        <h1>Coaches Hub</h1>
        <p>Enter your coaching portal PIN to continue.</p>
        <input id="pin-input" type="password" placeholder="PIN" autocomplete="off" />
        <button id="pin-submit">Enter</button>
        <p id="pin-error" class="pin-error" hidden>Incorrect PIN — check with your Technical Director.</p>
      </div>
    </div>
  )}

  <div id="hub-content" class={PIN ? 'hub-hidden' : ''}>

    <div class="page-hero">
      <div class="page-hero-inner">
        <div class="label">Coaches Only</div>
        <h1>Coaches Hub</h1>
        <p>Session plans, resources and development tools from your Technical Director.</p>
      </div>
    </div>

    <section class="section">
      <div class="hub-grid">

        <a href="/coaching/sessions" class="hub-card card">
          <div class="hub-icon">📋</div>
          <div class="hub-body">
            <h2>Session Plans</h2>
            <p>Full 90-minute session plans in Football Australia format, organised by age group and theme.</p>
          </div>
          <div class="hub-footer">Browse Plans →</div>
        </a>

        <a href="/coaching/resources" class="hub-card card">
          <div class="hub-icon">📚</div>
          <div class="hub-body">
            <h2>Resources</h2>
            <p>Videos, drill sheets, PDFs and articles from Football Australia, Football NSW and your club TD.</p>
          </div>
          <div class="hub-footer">View Resources →</div>
        </a>

        <div class="hub-card card hub-card--info">
          <div class="hub-icon">🏆</div>
          <div class="hub-body">
            <h2>FA Coaching Framework</h2>
            <p>All session plans follow the Football Australia 5-phase structure: Welcome → Warm Up → Positioning → Game Training → Training Game → Wrap Up.</p>
            <a href="https://footballaustralia.com.au/coaching-resources" target="_blank" rel="noopener" class="ext-link">Football Australia Coaching Resources ↗</a>
          </div>
        </div>

        <div class="hub-card card hub-card--info">
          <div class="hub-icon">📞</div>
          <div class="hub-body">
            <h2>Contact Technical Director</h2>
            <p>Questions about session delivery, player development or the coaching program? Reach out via the club email.</p>
            <a href="mailto:info@southwagga.com.au" class="ext-link">info@southwagga.com.au</a>
          </div>
        </div>

      </div>
    </section>

  </div>

</Base>

<script define:vars={{ PIN }}>
  const gate    = document.getElementById('pin-gate');
  const content = document.getElementById('hub-content');
  const input   = document.getElementById('pin-input');
  const btn     = document.getElementById('pin-submit');
  const err     = document.getElementById('pin-error');

  if (!PIN) return;

  const STORAGE_KEY = 'warriors_coaching_pin';

  function unlock() {
    if (gate)    gate.style.display = 'none';
    if (content) content.classList.remove('hub-hidden');
  }

  // Already unlocked this session?
  if (sessionStorage.getItem(STORAGE_KEY) === PIN) unlock();

  if (btn) {
    btn.addEventListener('click', () => {
      if (input.value === PIN) {
        sessionStorage.setItem(STORAGE_KEY, PIN);
        unlock();
      } else {
        err.hidden = false;
        input.value = '';
        input.focus();
      }
    });
    input.addEventListener('keydown', e => { if (e.key === 'Enter') btn.click(); });
  }
</script>

<style>
.gate          { position: fixed; inset: 0; background: var(--off-black); display: flex; align-items: center; justify-content: center; z-index: 100; }
.gate-box      { max-width: 380px; width: 90%; padding: 40px; text-align: center; display: flex; flex-direction: column; gap: 16px; }
.gate-logo     { font-size: 48px; }
.gate-box h1   { font-family: var(--font-cond); font-size: 32px; }
.gate-box p    { color: var(--muted); font-size: 14px; }
#pin-input     { background: var(--surface-2); border: 1px solid var(--border); color: var(--text); padding: 12px 16px; font-size: 18px; letter-spacing: 4px; text-align: center; border-radius: 4px; }
#pin-submit    { background: var(--green); color: #fff; border: none; padding: 12px; font-family: var(--font-cond); font-size: 14px; font-weight: 700; letter-spacing: 2px; text-transform: uppercase; cursor: pointer; border-radius: 4px; }
#pin-submit:hover { background: var(--green-bright); }
.pin-error     { color: #e05555; font-size: 13px; }
.hub-hidden    { display: none; }
.page-hero     { background: linear-gradient(135deg, var(--green-dark), var(--off-black)); border-bottom: 1px solid var(--border); padding: 60px 48px 48px; }
.page-hero-inner { max-width: 1280px; margin: 0 auto; }
.page-hero h1  { font-size: clamp(48px, 6vw, 80px); margin: 10px 0 8px; }
.page-hero p   { color: var(--muted); }
.section       { padding: 60px 48px; max-width: 1280px; margin: 0 auto; }
.hub-grid      { display: grid; grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); gap: 20px; }
.hub-card      { display: flex; flex-direction: column; text-decoration: none; transition: transform 0.2s, border-color 0.2s; }
.hub-card:not(.hub-card--info):hover { transform: translateY(-4px); border-color: var(--green); }
.hub-card--info { cursor: default; }
.hub-icon      { font-size: 36px; padding: 24px 24px 0; }
.hub-body      { padding: 16px 24px; flex: 1; }
.hub-body h2   { font-family: var(--font-cond); font-size: 22px; font-weight: 800; margin-bottom: 8px; }
.hub-body p    { color: var(--muted); font-size: 14px; line-height: 1.6; }
.hub-footer    { padding: 14px 24px; border-top: 1px solid var(--border); font-family: var(--font-cond); font-size: 13px; font-weight: 600; letter-spacing: 1px; color: var(--green-bright); }
.ext-link      { display: inline-block; margin-top: 10px; color: var(--green-bright); font-size: 13px; text-decoration: none; }
.ext-link:hover { text-decoration: underline; }
@media (max-width: 768px) { .page-hero { padding: 40px 20px 32px; } .section { padding: 40px 20px; } }
</style>
