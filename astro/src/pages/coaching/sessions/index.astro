---
// src/pages/coaching/sessions/index.astro
import Base from '../../../layouts/Base.astro';
import { getSessionPlans } from '../../../lib/sessions.js';

const plans = await getSessionPlans() || [];

const ageGroups = ['u5-u7','u8-u11','u12-u13','u14-u16','senior'];
const ageLabels = { 'u5-u7':'MiniRoos 5–7', 'u8-u11':'MiniRoos 8–11', 'u12-u13':'Youth U12–U13', 'u14-u16':'Youth U14–U16', 'senior':'Senior / U17–U18' };

// Group by age group
const grouped = ageGroups.reduce((acc, ag) => {
  const group = plans.filter(p => p.age_group === ag);
  if (group.length) acc[ag] = group;
  return acc;
}, {});
---
<Base title="Session Plans — Coaches Hub" description="Football Australia format session plans for Warriors FC coaches.">

  <div class="page-hero">
    <div class="page-hero-inner">
      <a href="/coaching" class="back-link">← Coaches Hub</a>
      <div class="label">Football Australia Format</div>
      <h1>Session Plans</h1>
      <p>90-minute session plans organised by age group and theme. Tap a plan to open the full session on your device.</p>
    </div>
  </div>

  <section class="section">

    {plans.length === 0 && (
      <p class="empty">No session plans published yet — check back soon.</p>
    )}

    {Object.entries(grouped).map(([ag, agPlans]) => (
      <div class="age-group-block">
        <h2 class="age-heading">{ageLabels[ag] ?? ag}</h2>
        <div class="plans-grid">
          {agPlans.map(plan => (
            <a href={`/coaching/sessions/${plan.slug}`} class="plan-card card">
              <div class="plan-theme">{plan.theme || 'General'}</div>
              <h3>{plan.title}</h3>
              <div class="plan-meta">
                {plan.duration && <span>⏱ {plan.duration} min</span>}
                {plan.player_numbers && <span>👥 {plan.player_numbers}</span>}
              </div>
              {plan.objectives && <p class="plan-obj">{plan.objectives}</p>}
              <div class="plan-footer">View Session Plan →</div>
            </a>
          ))}
        </div>
      </div>
    ))}

  </section>

</Base>

<style>
.page-hero        { background: linear-gradient(135deg, var(--green-dark), var(--off-black)); border-bottom: 1px solid var(--border); padding: 60px 48px 48px; }
.page-hero-inner  { max-width: 1280px; margin: 0 auto; }
.back-link        { color: var(--green-bright); font-size: 13px; text-decoration: none; display: inline-block; margin-bottom: 16px; }
.back-link:hover  { text-decoration: underline; }
.page-hero h1     { font-size: clamp(40px, 5vw, 72px); margin: 10px 0 8px; }
.page-hero p      { color: var(--muted); max-width: 600px; }
.section          { padding: 60px 48px; max-width: 1280px; margin: 0 auto; }
.age-group-block  { margin-bottom: 48px; }
.age-heading      { font-family: var(--font-cond); font-size: 13px; font-weight: 700; letter-spacing: 3px; text-transform: uppercase; color: var(--green-bright); border-bottom: 1px solid var(--border); padding-bottom: 10px; margin-bottom: 20px; }
.plans-grid       { display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 16px; }
.plan-card        { display: flex; flex-direction: column; text-decoration: none; transition: transform 0.2s, border-color 0.2s; }
.plan-card:hover  { transform: translateY(-3px); border-color: var(--green); }
.plan-theme       { font-family: var(--font-cond); font-size: 11px; font-weight: 700; letter-spacing: 2px; text-transform: uppercase; color: var(--green-bright); padding: 16px 16px 0; }
.plan-card h3     { font-family: var(--font-cond); font-size: 20px; font-weight: 800; padding: 6px 16px 0; }
.plan-meta        { display: flex; gap: 12px; padding: 8px 16px; font-size: 12px; color: var(--muted); }
.plan-obj         { font-size: 13px; color: var(--muted); padding: 0 16px; flex: 1; line-height: 1.5; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }
.plan-footer      { margin-top: auto; padding: 12px 16px; border-top: 1px solid var(--border); font-family: var(--font-cond); font-size: 12px; font-weight: 600; letter-spacing: 1px; color: var(--green-bright); }
.empty            { color: var(--muted); font-style: italic; }
@media (max-width: 768px) { .page-hero { padding: 40px 20px 32px; } .section { padding: 40px 20px; } }
</style>
