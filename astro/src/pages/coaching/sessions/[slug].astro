---
// src/pages/coaching/sessions/[slug].astro
import Base from '../../../layouts/Base.astro';
import { getSessionPlan, getAllSessionPlanSlugs } from '../../../lib/sessions.js';

export async function getStaticPaths() {
  const slugs = await getAllSessionPlanSlugs();
  return slugs.filter(s => s).map(slug => ({ params: { slug } }));
}

const { slug } = Astro.params;
const plan = await getSessionPlan(slug);
if (!plan) return Astro.redirect('/coaching/sessions');

const ageLabels: Record<string,string> = {
  'u5-u7':'MiniRoos 5–7', 'u8-u11':'MiniRoos 8–11',
  'u12-u13':'Youth U12–U13', 'u14-u16':'Youth U14–U16',
  senior:'Senior / U17–U18',
};

// ── PHASES CONFIG ──────────────────────────────────────────────────────────────
const phases = [
  {
    id:       'welcome',
    label:    'Welcome & Explanation',
    time:     '5 min',
    icon:     '👋',
    desc:     plan.phase_welcome_notes,
    note:     'Introduce the theme. Ask players what they know. Set expectations.',
  },
  {
    id:       'warmup',
    label:    plan.phase_warmup_title ? `Warm Up — ${plan.phase_warmup_title}` : 'Warm Up',
    time:     '10–20 min',
    icon:     '🏃',
    desc:     plan.phase_warmup_description,
    setup:    plan.phase_warmup_setup,
    activities: plan.phase_warmup_activities,
    points:   plan.phase_warmup_coaching_points,
    progress: plan.phase_warmup_progressions,
    note:     'With the ball, theme-related. Build physical readiness and introduce the session focus.',
  },
  {
    id:       'positioning',
    label:    plan.phase_positioning_title ? `Skill Practice — ${plan.phase_positioning_title}` : 'Positioning & Skill Practice',
    time:     '15–20 min',
    icon:     '🔲',
    desc:     plan.phase_positioning_description,
    setup:    plan.phase_positioning_setup,
    points:   plan.phase_positioning_coaching_points,
    progress: plan.phase_positioning_progressions,
    rules:    plan.phase_positioning_rules,
    note:     'Focused practice reinforcing the session theme in a controlled environment.',
  },
  {
    id:       'game_training',
    label:    plan.phase_game_training_title ? `Conditioned Game — ${plan.phase_game_training_title}` : 'Game Training',
    time:     '20–25 min',
    icon:     '🎯',
    desc:     plan.phase_game_training_description,
    setup:    plan.phase_game_training_setup,
    points:   plan.phase_game_training_coaching_points,
    progress: plan.phase_game_training_progressions,
    rules:    plan.phase_game_training_rules,
    note:     'Apply the skill in a game-realistic scenario with rules/restraints that expose the theme.',
  },
  {
    id:       'training_game',
    label:    plan.phase_training_game_title ? `Training Game — ${plan.phase_training_game_title}` : 'Training Game',
    time:     '15–25 min',
    icon:     '⚽',
    desc:     plan.phase_training_game_description,
    rules:    plan.phase_training_game_rules,
    points:   plan.phase_training_game_coaching_points,
    note:     'Match play with rules/restraints emphasising the team task. Let them play.',
  },
  {
    id:       'warmdown',
    label:    'Warm Down & Wrap Up',
    time:     '5 min',
    icon:     '✅',
    desc:     plan.phase_warmdown_notes,
    note:     'Cool down, questions, reflection. What did we learn?',
  },
];

const hasContent = (p: any) => p.desc || p.activities || p.setup;
---
<Base title={`${plan.title} — Session Plan`} description={plan.objectives || ''}>

  <div class="page-hero">
    <div class="page-hero-inner">
      <a href="/coaching/sessions" class="back-link">← Session Plans</a>
      {plan.age_group && <div class="label">{ageLabels[plan.age_group] ?? plan.age_group}</div>}
      <h1>{plan.title}</h1>
      <div class="plan-meta">
        {plan.theme        && <span class="meta-tag">{plan.theme}</span>}
        {plan.duration     && <span class="meta-tag">⏱ {plan.duration} min</span>}
        {plan.player_numbers && <span class="meta-tag">👥 {plan.player_numbers}</span>}
        {plan.week         && <span class="meta-tag">Week {plan.week}</span>}
      </div>
    </div>
  </div>

  <div class="plan-layout">

    <!-- Sidebar -->
    <aside class="plan-sidebar">
      {plan.objectives && (
        <div class="sidebar-block card">
          <h3>Session Objectives</h3>
          {Array.isArray(plan.objectives)
            ? <ul class="obj-list">{(plan.objectives as string[]).map((o: string) => <li>{o}</li>)}</ul>
            : <ul class="obj-list">{(plan.objectives as string).split('\n').filter(Boolean).map((o:string) => <li>{o}</li>)}</ul>
          }
        </div>
      )}
      {plan.equipment && (
        <div class="sidebar-block card">
          <h3>Equipment</h3>
          <p>{plan.equipment}</p>
        </div>
      )}
      <div class="sidebar-block card sidebar-timeline">
        <h3>Session Flow</h3>
        {phases.filter(p => hasContent(p) || p.id === 'welcome' || p.id === 'warmdown').map(p => (
          <a href={`#${p.id}`} class="timeline-item">
            <span class="tl-icon">{p.icon}</span>
            <span class="tl-label">{p.label.split(' — ')[0]}</span>
            <span class="tl-time">{p.time}</span>
          </a>
        ))}
      </div>
      {plan.td_notes && (
        <div class="sidebar-block card sidebar-td">
          <h3>TD Notes</h3>
          <p>{plan.td_notes}</p>
        </div>
      )}
    </aside>

    <!-- Phases -->
    <main class="plan-phases">
      {phases.map((phase, i) => {
        if (!hasContent(phase) && phase.id !== 'welcome' && phase.id !== 'warmdown') return null;
        if (!hasContent(phase)) return null;
        const points: string[] | null = (phase as any).points;
        return (
          <section id={phase.id} class="phase-block card">
            <div class="phase-header">
              <span class="phase-num">{i + 1}</span>
              <span class="phase-icon">{phase.icon}</span>
              <div class="phase-title-group">
                <h2>{phase.label}</h2>
                <span class="phase-time">{phase.time}</span>
              </div>
            </div>
            <p class="phase-framework-note">{phase.note}</p>

            {phase.desc && (
              <div class="phase-section">
                <h4>Activity</h4>
                <p class="activity-text">{phase.desc}</p>
              </div>
            )}

            {(phase as any).setup && (
              <div class="phase-section phase-section--setup">
                <h4>⚙️ Setup</h4>
                <p class="activity-text setup-text">{(phase as any).setup}</p>
              </div>
            )}

            {(phase as any).activities && (
              <div class="phase-section">
                <h4>Activities</h4>
                <ul class="activity-list">
                  {((phase as any).activities as string).split('\n').filter(Boolean).map((a: string) => (
                    <li>{a}</li>
                  ))}
                </ul>
              </div>
            )}

            {(phase as any).rules && (
              <div class="phase-section phase-section--amber">
                <h4>📋 Rules &amp; Restraints</h4>
                <p class="whitespace">{(phase as any).rules}</p>
              </div>
            )}

            {(phase as any).progress && (
              <div class="phase-section phase-section--muted">
                <h4>📈 Progressions</h4>
                <p class="whitespace">{(phase as any).progress}</p>
              </div>
            )}

            {/* ── COACHING CUES ── */}
            {points && points.length > 0 && (
              <div class="coaching-cues">
                <div class="cues-header">
                  <span class="cues-icon">🔍</span>
                  <span>Look For — Coaching Cues</span>
                </div>
                <div class="cues-grid">
                  {points.map((pt: string) => (
                    <div class="cue-item">
                      <span class="cue-check">✓</span>
                      <span class="cue-text">{pt}</span>
                    </div>
                  ))}
                </div>
                <div class="intervention-tip">
                  <span class="int-label">💬 Intervention:</span>
                  <span class="int-text">Freeze the drill · demonstrate · ask a guiding question · resume. Keep stoppages under 45 seconds.</span>
                </div>
              </div>
            )}
          </section>
        );
      })}
    </main>

  </div>

</Base>

<style>
.page-hero          { background: linear-gradient(135deg, var(--green-dark), var(--off-black)); border-bottom: 1px solid var(--border); padding: 60px 48px 48px; }
.page-hero-inner    { max-width: 1280px; margin: 0 auto; }
.back-link          { color: var(--green-bright); font-size: 13px; text-decoration: none; display: inline-block; margin-bottom: 16px; }
.back-link:hover    { text-decoration: underline; }
.page-hero h1       { font-size: clamp(32px, 4vw, 60px); margin: 10px 0 12px; }
.plan-meta          { display: flex; flex-wrap: wrap; gap: 8px; }
.meta-tag           { background: rgba(255,255,255,0.08); border: 1px solid var(--border); padding: 4px 12px; border-radius: 20px; font-size: 13px; color: var(--muted); }

.plan-layout        { display: grid; grid-template-columns: 280px 1fr; gap: 32px; max-width: 1280px; margin: 0 auto; padding: 40px 48px 80px; }

/* Sidebar */
.plan-sidebar       { display: flex; flex-direction: column; gap: 16px; }
.sidebar-block      { padding: 20px; }
.sidebar-block h3   { font-family: var(--font-cond); font-size: 12px; font-weight: 700; letter-spacing: 2px; text-transform: uppercase; color: var(--green-bright); margin-bottom: 10px; }
.sidebar-block p    { font-size: 13px; color: var(--muted); line-height: 1.6; white-space: pre-line; }
.obj-list           { margin: 0; padding-left: 16px; font-size: 13px; color: var(--muted); line-height: 1.7; }
.obj-list li        { margin-bottom: 4px; }
.sidebar-td         { border-color: var(--green); }
.timeline-item      { display: flex; align-items: center; gap: 8px; padding: 8px 0; border-bottom: 1px solid var(--border); text-decoration: none; color: var(--text); font-size: 13px; }
.timeline-item:last-child { border-bottom: none; }
.timeline-item:hover .tl-label { color: var(--green-bright); }
.tl-icon            { font-size: 16px; width: 24px; text-align: center; }
.tl-label           { flex: 1; }
.tl-time            { font-size: 11px; color: var(--muted); white-space: nowrap; }

/* Phases */
.plan-phases        { display: flex; flex-direction: column; gap: 24px; }
.phase-block        { padding: 0; overflow: hidden; }
.phase-header       { display: flex; align-items: center; gap: 12px; padding: 20px 24px; background: var(--surface-2); border-bottom: 1px solid var(--border); }
.phase-num          { font-family: var(--font-cond); font-size: 13px; font-weight: 700; color: var(--muted); width: 20px; }
.phase-icon         { font-size: 24px; }
.phase-title-group  { flex: 1; }
.phase-title-group h2 { font-family: var(--font-cond); font-size: 18px; font-weight: 800; margin: 0; line-height: 1.2; }
.phase-time         { font-size: 12px; color: var(--green-bright); font-weight: 600; }
.phase-framework-note { font-size: 12px; color: var(--muted); font-style: italic; padding: 10px 24px; border-bottom: 1px solid var(--border); margin: 0; }

.phase-section      { padding: 18px 24px; border-bottom: 1px solid var(--border); }
.phase-section:last-child { border-bottom: none; }
.phase-section h4   { font-family: var(--font-cond); font-size: 11px; font-weight: 700; letter-spacing: 2px; text-transform: uppercase; color: var(--muted); margin-bottom: 10px; }
.phase-section--setup { background: rgba(255,255,255,0.02); }
.phase-section--setup h4 { color: #888; }
.phase-section--amber { background: rgba(255, 180, 0, 0.06); }
.phase-section--amber h4 { color: #ffb400; }
.phase-section--muted { background: rgba(255,255,255,0.02); }
.activity-text      { font-size: 14px; line-height: 1.75; color: var(--text); margin: 0; }
.setup-text         { color: var(--muted); font-size: 13px; }
.activity-list      { margin: 0; padding-left: 20px; font-size: 14px; line-height: 1.7; color: var(--muted); }
.activity-list li   { margin-bottom: 4px; }
.whitespace         { white-space: pre-line; font-size: 14px; line-height: 1.7; color: var(--text); }

/* Coaching cues */
.coaching-cues      { border-top: 2px solid var(--green); background: rgba(37, 160, 76, 0.05); padding: 20px 24px; }
.cues-header        { display: flex; align-items: center; gap: 8px; font-family: var(--font-cond); font-size: 12px; font-weight: 700; letter-spacing: 2px; text-transform: uppercase; color: var(--green-bright); margin-bottom: 14px; }
.cues-icon          { font-size: 16px; }
.cues-grid          { display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 8px 20px; margin-bottom: 14px; }
.cue-item           { display: flex; align-items: flex-start; gap: 8px; font-size: 13px; line-height: 1.5; }
.cue-check          { color: var(--green-bright); font-weight: 700; margin-top: 1px; flex-shrink: 0; }
.cue-text           { color: var(--text); }
.intervention-tip   { border-top: 1px solid rgba(37,160,76,0.2); padding-top: 12px; font-size: 12px; color: var(--muted); }
.int-label          { color: var(--green-bright); font-weight: 600; margin-right: 6px; }

@media (max-width: 900px) {
  .plan-layout { grid-template-columns: 1fr; padding: 24px 20px 60px; }
  .plan-sidebar { display: contents; }
  .sidebar-timeline { order: -1; }
  .page-hero { padding: 40px 20px 32px; }
}
@media (max-width: 600px) {
  .cues-grid { grid-template-columns: 1fr; }
}
</style>
