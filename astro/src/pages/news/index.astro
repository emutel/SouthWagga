---
// src/pages/news/index.astro
import Base from '../../layouts/Base.astro';
import { getNews, fileUrl } from '../../lib/directus.js';

const news = await getNews({ limit: 50 }) || [];
const featured = news.filter(n => n.featured).slice(0, 1)[0];
const rest = news.filter(n => !featured || n.id !== featured.id);
---
<Base title="News" description="Latest news and announcements from South Wagga Warriors FC.">

  <div class="page-hero">
    <div class="page-hero-inner">
      <div class="label">Club News</div>
      <h1>Latest News</h1>
    </div>
  </div>

  <div class="page-inner">

    <!-- Featured article -->
    {featured && (
      <a href={`/news/${featured.slug}`} class="featured-article card">
        {featured.hero_image && (
          <img
            src={fileUrl(featured.hero_image, { width: 1200, height: 500 })}
            alt={featured.title}
            class="featured-img"
            loading="eager"
          />
        )}
        <div class="featured-body">
          <div class="featured-tag">Featured</div>
          <h2>{featured.title}</h2>
          {featured.excerpt && <p>{featured.excerpt}</p>}
          <div class="article-meta">
            {new Date(featured.date_created).toLocaleDateString('en-AU',{day:'numeric',month:'long',year:'numeric'})}
            {featured.author && ` · ${featured.author}`}
          </div>
        </div>
      </a>
    )}

    <!-- Article grid -->
    {rest.length > 0 && (
      <div class="news-grid">
        {rest.map(article => (
          <a href={`/news/${article.slug}`} class="news-card card">
            {article.hero_image ? (
              <img
                src={fileUrl(article.hero_image, { width: 600, height: 340 })}
                alt={article.title}
                class="news-img"
                loading="lazy"
              />
            ) : (
              <div class="news-img-placeholder">
                <span>📰</span>
              </div>
            )}
            <div class="news-body">
              <div class="article-meta">
                {new Date(article.date_created).toLocaleDateString('en-AU',{day:'numeric',month:'long',year:'numeric'})}
                {article.author && ` · ${article.author}`}
              </div>
              <h3>{article.title}</h3>
              {article.excerpt && <p>{article.excerpt}</p>}
            </div>
          </a>
        ))}
      </div>
    )}

    {news.length === 0 && (
      <p class="empty">No news articles published yet.</p>
    )}
  </div>

</Base>

<style>
.page-hero { background:linear-gradient(135deg,var(--green-dark),var(--off-black)); border-bottom:1px solid var(--border); padding:60px 48px 48px; }
.page-hero-inner { max-width:1280px; margin:0 auto; }
.page-hero h1 { font-size:clamp(48px,6vw,80px); margin:10px 0; }

.page-inner { max-width:1280px; margin:0 auto; padding:48px; }

.featured-article { display:grid; grid-template-columns:1.4fr 1fr; margin-bottom:48px; text-decoration:none; transition:border-color 0.2s; }
.featured-article:hover { border-color:var(--green); }
.featured-img { width:100%; height:360px; object-fit:cover; }
.featured-body { padding:36px; display:flex; flex-direction:column; justify-content:center; }
.featured-tag { font-family:var(--font-cond); font-size:11px; font-weight:700; letter-spacing:2px; text-transform:uppercase; color:var(--green-bright); margin-bottom:12px; }
.featured-body h2 { font-family:var(--font-cond); font-size:28px; font-weight:800; line-height:1.25; margin-bottom:12px; }
.featured-body p  { font-size:15px; color:var(--muted); line-height:1.6; margin-bottom:16px; }

.news-grid { display:grid; grid-template-columns:repeat(auto-fill,minmax(300px,1fr)); gap:20px; }
.news-card { text-decoration:none; display:flex; flex-direction:column; transition:transform 0.2s,border-color 0.2s; }
.news-card:hover { transform:translateY(-4px); border-color:var(--green); }
.news-img { width:100%; aspect-ratio:16/9; object-fit:cover; }
.news-img-placeholder { width:100%; aspect-ratio:16/9; background:var(--green-dark); display:flex; align-items:center; justify-content:center; font-size:40px; }
.news-body { padding:20px; flex:1; }
.news-body h3 { font-family:var(--font-cond); font-size:20px; font-weight:700; line-height:1.3; margin:6px 0 8px; }
.news-body p  { font-size:14px; color:var(--muted); line-height:1.5; }
.article-meta { font-size:12px; color:var(--muted); }
.empty { color:var(--muted); font-style:italic; padding:40px 0; }

@media (max-width:768px) {
  .page-hero { padding:40px 20px 32px; }
  .page-inner { padding:24px 20px; }
  .featured-article { grid-template-columns:1fr; }
  .featured-img { height:220px; }
  .featured-body { padding:20px; }
}
</style>
