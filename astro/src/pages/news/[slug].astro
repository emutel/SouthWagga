---
// src/pages/news/[slug].astro
import Base      from '../../layouts/Base.astro';
import ShareBar  from '../../components/ShareBar.astro';
import { getNewsArticle, getAllNewsSlugs, getNews, fileUrl } from '../../lib/directus.js';

export async function getStaticPaths() {
  const slugs = await getAllNewsSlugs();
  return slugs.filter(slug => slug).map(slug => ({ params: { slug } }));
}

const { slug }  = Astro.params;
const article   = await getNewsArticle(slug);
if (!article) return Astro.redirect('/news');

const related   = await getNews({ limit: 3 }) || [];
const others    = related.filter(a => a.id !== article.id).slice(0, 2);
---
<Base
  title={article.title}
  description={article.excerpt || article.title}
  ogImage={article.hero_image ? fileUrl(article.hero_image, { width:1200, height:630 }) : undefined}
>

  <article class="article-wrap">

    {article.hero_image && (
      <div class="article-hero">
        <img
          src={fileUrl(article.hero_image, { width:1400, height:560 })}
          alt={article.title}
          loading="eager"
        />
        <div class="article-hero-overlay"></div>
      </div>
    )}

    <div class="article-inner">

      <header class="article-header">
        <a href="/news" class="back-link">← News</a>
        <div class="article-meta">
          {new Date(article.date_created).toLocaleDateString('en-AU',{weekday:'long',day:'numeric',month:'long',year:'numeric'})}
          {article.author && <span> · By {article.author}</span>}
        </div>
        <h1>{article.title}</h1>
        {article.excerpt && <p class="article-excerpt">{article.excerpt}</p>}
      </header>

      <!-- Article body from Directus rich text -->
      <div class="article-body" set:html={article.body} />

      <!-- Tags -->
      {article.tags?.length > 0 && (
        <div class="article-tags">
          {article.tags.map(tag => <span class="tag">{tag}</span>)}
        </div>
      )}

      <ShareBar title={article.title} url={Astro.url.href} />

    </div>
  </article>

  <!-- Related articles -->
  {others.length > 0 && (
    <section class="related">
      <div class="related-inner">
        <div class="label" style="margin-bottom:24px">More News</div>
        <div class="related-grid">
          {others.map(a => (
            <a href={`/news/${a.slug}`} class="related-card card">
              {a.hero_image && (
                <img
                  src={fileUrl(a.hero_image, { width:600, height:340 })}
                  alt={a.title}
                  loading="lazy"
                  class="related-img"
                />
              )}
              <div class="related-body">
                <div class="article-meta">{new Date(a.date_created).toLocaleDateString('en-AU',{day:'numeric',month:'short',year:'numeric'})}</div>
                <h3>{a.title}</h3>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

</Base>

<style>
.article-wrap { max-width:100%; }

.article-hero { position:relative; height:480px; overflow:hidden; }
.article-hero img { width:100%; height:100%; object-fit:cover; }
.article-hero-overlay { position:absolute; inset:0; background:linear-gradient(to bottom, transparent 40%, rgba(9,12,9,0.9) 100%); }

.article-inner { max-width:760px; margin:0 auto; padding:48px 24px 64px; }

.back-link { font-family:var(--font-cond); font-size:13px; font-weight:600; letter-spacing:1px; color:var(--green-bright); text-decoration:none; display:inline-block; margin-bottom:24px; }
.back-link:hover { text-decoration:underline; }

.article-meta { font-size:13px; color:var(--muted); margin-bottom:12px; }

.article-header h1 { font-family:var(--font-cond); font-size:clamp(32px,5vw,52px); font-weight:800; line-height:1.15; letter-spacing:0.5px; margin-bottom:16px; }
.article-excerpt { font-size:18px; color:var(--muted); line-height:1.65; border-left:3px solid var(--green); padding-left:16px; margin-bottom:40px; }

.article-body { font-size:16px; line-height:1.75; color:rgba(238,245,239,0.85); }
.article-body h2 { font-family:var(--font-cond); font-size:26px; font-weight:700; margin:36px 0 14px; color:var(--white); }
.article-body h3 { font-family:var(--font-cond); font-size:20px; font-weight:700; margin:28px 0 10px; color:var(--white); }
.article-body p  { margin-bottom:20px; }
.article-body a  { color:var(--green-bright); }
.article-body img { border-radius:var(--radius); margin:24px 0; width:100%; }
.article-body ul, .article-body ol { padding-left:24px; margin-bottom:20px; }
.article-body li { margin-bottom:8px; }
.article-body blockquote { border-left:3px solid var(--green); padding-left:20px; color:var(--muted); font-style:italic; margin:24px 0; }

.article-tags { display:flex; gap:8px; flex-wrap:wrap; margin-top:32px; }
.tag { background:rgba(37,160,76,0.12); color:var(--green-bright); font-family:var(--font-cond); font-size:12px; font-weight:600; letter-spacing:1px; padding:4px 12px; border-radius:20px; }

.related { background:var(--off-black); border-top:1px solid var(--border); padding:56px 48px; }
.related-inner { max-width:1280px; margin:0 auto; }
.related-grid { display:grid; grid-template-columns:1fr 1fr; gap:20px; }
.related-card { text-decoration:none; transition:transform 0.2s,border-color 0.2s; }
.related-card:hover { transform:translateY(-4px); border-color:var(--green); }
.related-img  { width:100%; aspect-ratio:16/9; object-fit:cover; }
.related-body { padding:18px; }
.related-body h3 { font-family:var(--font-cond); font-size:18px; font-weight:700; margin-top:6px; line-height:1.3; }

@media (max-width:768px) {
  .article-hero { height:260px; }
  .article-inner { padding:32px 20px 48px; }
  .related { padding:40px 20px; }
  .related-grid { grid-template-columns:1fr; }
}
</style>
