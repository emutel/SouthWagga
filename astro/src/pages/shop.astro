---
// src/pages/shop.astro
import Base from '../layouts/Base.astro';
import { getShopItems, fileUrl } from '../lib/directus.js';

const items = await getShopItems() || [];
const categories = ['kit', 'merch', 'training', 'other'];
const catLabels  = { kit:'Kit & Jerseys', merch:'Merchandise', training:'Training Gear', other:'Other' };

const byCat = categories.reduce((acc, cat) => {
  acc[cat] = items.filter(i => i.category === cat && i.status !== 'hidden');
  return acc;
}, {});
---
<Base title="Warriors Shop" description="Official South Wagga Warriors FC merchandise, jerseys and training gear. Secure checkout via Square.">

  <div class="page-hero">
    <div class="page-hero-inner">
      <div class="label">Official Merchandise</div>
      <h1>Warriors Shop</h1>
      <p>Jerseys, training gear and club merchandise. All payments processed securely via Square.</p>
    </div>
  </div>

  <div class="page-inner">

    <!-- Category filter -->
    <div class="cat-tabs">
      <button class="cat-tab active" data-cat="all">All Items</button>
      {categories.filter(c => byCat[c]?.length > 0).map(c => (
        <button class="cat-tab" data-cat={c}>{catLabels[c]}</button>
      ))}
    </div>

    <!-- Items grid -->
    <div class="shop-grid" id="shop-grid">
      {items.filter(i => i.status !== 'hidden').map(item => (
        <div class={`shop-card card ${item.status === 'out_of_stock' ? 'out-of-stock' : ''}`} data-cat={item.category}>
          <div class="shop-img-wrap">
            {item.image ? (
              <img
                src={fileUrl(item.image, { width:480, height:480 })}
                alt={item.name}
                class="shop-img"
                loading="lazy"
              />
            ) : (
              <div class="shop-img-placeholder">⚽</div>
            )}
            {item.badge && <span class="item-badge">{item.badge}</span>}
            {item.status === 'out_of_stock' && <div class="oos-overlay">Out of Stock</div>}
          </div>
          <div class="shop-body">
            <h3>{item.name}</h3>
            {item.description && <p>{item.description}</p>}
            <div class="shop-footer">
              <span class="item-price">${parseFloat(item.price || 0).toFixed(0)}</span>
              {item.square_url && item.status !== 'out_of_stock' ? (
                <a href={item.square_url} target="_blank" rel="noopener" class="btn btn-primary btn-sm">
                  Buy Now →
                </a>
              ) : item.status === 'out_of_stock' ? (
                <span class="oos-label">Out of Stock</span>
              ) : (
                <a href="/about#contact" class="btn btn-secondary btn-sm">Enquire</a>
              )}
            </div>
          </div>
        </div>
      ))}
      {items.length === 0 && (
        <p class="empty">Shop items coming soon.</p>
      )}
    </div>

    <!-- Square trust badge -->
    <div class="trust-badge">
      <span class="trust-icon">🔒</span>
      <div>
        <strong>Secure payments via Square</strong>
        <p>Cards, Apple Pay and Google Pay accepted. You'll be taken to Square's secure checkout.</p>
      </div>
    </div>

  </div>

</Base>

<script>
  document.querySelectorAll('.cat-tab').forEach(tab => {
    tab.addEventListener('click', () => {
      document.querySelectorAll('.cat-tab').forEach(t => t.classList.remove('active'));
      tab.classList.add('active');
      const cat = tab.dataset.cat;
      document.querySelectorAll('.shop-card').forEach(card => {
        card.style.display = (cat === 'all' || card.dataset.cat === cat) ? '' : 'none';
      });
    });
  });
</script>

<style>
.page-hero { background:linear-gradient(135deg,var(--green-dark),var(--off-black)); border-bottom:1px solid var(--border); padding:60px 48px 48px; }
.page-hero-inner { max-width:1280px; margin:0 auto; }
.page-hero h1 { font-size:clamp(48px,6vw,80px); margin:10px 0 8px; }
.page-hero p  { color:var(--muted); }

.page-inner { max-width:1280px; margin:0 auto; padding:48px; }

.cat-tabs { display:flex; flex-wrap:wrap; gap:8px; margin-bottom:32px; }
.cat-tab  { padding:7px 18px; background:var(--card); border:1px solid var(--border); border-radius:20px; font-family:var(--font-cond); font-size:13px; font-weight:600; letter-spacing:1px; color:var(--muted); cursor:pointer; transition:all 0.15s; }
.cat-tab.active, .cat-tab:hover { background:var(--green); border-color:var(--green); color:#fff; }

.shop-grid { display:grid; grid-template-columns:repeat(auto-fill,minmax(240px,1fr)); gap:20px; margin-bottom:40px; }

.shop-card { display:flex; flex-direction:column; transition:transform 0.2s,border-color 0.2s; }
.shop-card:hover { transform:translateY(-4px); border-color:var(--green); }
.shop-card.out-of-stock { opacity:0.6; }

.shop-img-wrap { position:relative; aspect-ratio:1; overflow:hidden; background:var(--green-dark); }
.shop-img { width:100%; height:100%; object-fit:cover; transition:transform 0.3s; }
.shop-card:hover .shop-img { transform:scale(1.04); }
.shop-img-placeholder { width:100%; height:100%; display:flex; align-items:center; justify-content:center; font-size:56px; }
.item-badge { position:absolute; top:10px; right:10px; background:var(--green); color:#fff; font-family:var(--font-cond); font-size:11px; font-weight:700; letter-spacing:1px; text-transform:uppercase; padding:3px 9px; border-radius:3px; }
.oos-overlay { position:absolute; inset:0; background:rgba(9,12,9,0.6); display:flex; align-items:center; justify-content:center; font-family:var(--font-cond); font-size:16px; font-weight:700; letter-spacing:1px; color:var(--white); }

.shop-body { padding:18px; flex:1; display:flex; flex-direction:column; }
.shop-body h3 { font-family:var(--font-cond); font-size:18px; font-weight:700; margin-bottom:6px; }
.shop-body p  { font-size:13px; color:var(--muted); line-height:1.5; flex:1; margin-bottom:14px; }

.shop-footer  { display:flex; align-items:center; justify-content:space-between; gap:12px; margin-top:auto; }
.item-price   { font-family:var(--font-display); font-size:32px; color:var(--green-bright); letter-spacing:1px; }
.oos-label    { font-family:var(--font-cond); font-size:12px; font-weight:600; letter-spacing:1px; color:var(--muted); }
.btn-sm       { padding:8px 16px; font-size:13px; }

.trust-badge { display:flex; align-items:center; gap:16px; background:var(--card); border:1px solid var(--border); border-radius:var(--radius); padding:20px 24px; max-width:500px; }
.trust-icon  { font-size:28px; flex-shrink:0; }
.trust-badge strong { display:block; font-family:var(--font-cond); font-size:15px; font-weight:700; margin-bottom:3px; }
.trust-badge p { font-size:13px; color:var(--muted); }
.empty { color:var(--muted); font-style:italic; grid-column:1/-1; padding:40px 0; }

@media (max-width:768px) {
  .page-hero { padding:40px 20px 32px; }
  .page-inner { padding:24px 20px; }
}
</style>
