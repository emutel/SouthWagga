---
// src/pages/gallery/[id].astro
import Base from '../../layouts/Base.astro';
import { getGalleryAlbums, getAlbumPhotos, fileUrl } from '../../lib/directus.js';

export async function getStaticPaths() {
  const albums = await getGalleryAlbums({ limit: 100 });
  return (albums || []).map(a => ({ params: { id: a.id } }));
}

const { id }   = Astro.params;
const albums   = await getGalleryAlbums({ limit: 100 });
const album    = albums?.find(a => a.id === id);
if (!album) return Astro.redirect('/gallery');

const photos   = await getAlbumPhotos(id) || [];
---
<Base
  title={album.title}
  description={album.description || `${album.title} — Warriors FC Gallery`}
>

  <div class="page-hero">
    <div class="page-hero-inner">
      <a href="/gallery" class="back-link">← Gallery</a>
      <div class="label">
        {album.date ? new Date(album.date).toLocaleDateString('en-AU',{day:'numeric',month:'long',year:'numeric'}) : 'Photo Album'}
      </div>
      <h1>{album.title}</h1>
      {album.description && <p>{album.description}</p>}
    </div>
  </div>

  <div class="page-inner">
    {photos.length > 0 ? (
      <div class="photo-grid" id="photo-grid">
        {photos.map((photo, i) => (
          <button
            class="photo-cell"
            data-index={i}
            data-src={fileUrl(photo.image, { width: 1400 })}
            data-caption={photo.caption || ''}
            aria-label={photo.caption || `Photo ${i + 1}`}
          >
            <img
              src={fileUrl(photo.image, { width: 600, height: 400 })}
              alt={photo.caption || ''}
              loading="lazy"
            />
            {photo.caption && <span class="photo-caption">{photo.caption}</span>}
          </button>
        ))}
      </div>
    ) : (
      <p class="empty">No photos in this album yet.</p>
    )}
  </div>

  <!-- Lightbox -->
  <div class="lightbox" id="lightbox" aria-hidden="true">
    <button class="lb-close" id="lb-close" aria-label="Close">✕</button>
    <button class="lb-prev"  id="lb-prev"  aria-label="Previous">‹</button>
    <button class="lb-next"  id="lb-next"  aria-label="Next">›</button>
    <div class="lb-img-wrap">
      <img id="lb-img" src="" alt="">
      <p id="lb-caption" class="lb-caption"></p>
    </div>
  </div>

</Base>

<script>
  const cells   = Array.from(document.querySelectorAll('.photo-cell'));
  const lb      = document.getElementById('lightbox');
  const lbImg   = document.getElementById('lb-img');
  const lbCap   = document.getElementById('lb-caption');
  let   current = 0;

  function open(i) {
    current = i;
    const cell = cells[i];
    lbImg.src  = cell.dataset.src;
    lbImg.alt  = cell.dataset.caption || '';
    lbCap.textContent = cell.dataset.caption || '';
    lb.classList.add('open');
    lb.setAttribute('aria-hidden', 'false');
    document.body.style.overflow = 'hidden';
  }

  function close() {
    lb.classList.remove('open');
    lb.setAttribute('aria-hidden', 'true');
    document.body.style.overflow = '';
  }

  function prev() { open((current - 1 + cells.length) % cells.length); }
  function next() { open((current + 1) % cells.length); }

  cells.forEach((cell, i) => cell.addEventListener('click', () => open(i)));
  document.getElementById('lb-close')?.addEventListener('click', close);
  document.getElementById('lb-prev')?.addEventListener('click', prev);
  document.getElementById('lb-next')?.addEventListener('click', next);
  lb?.addEventListener('click', e => { if (e.target === lb) close(); });

  document.addEventListener('keydown', e => {
    if (!lb?.classList.contains('open')) return;
    if (e.key === 'Escape')     close();
    if (e.key === 'ArrowLeft')  prev();
    if (e.key === 'ArrowRight') next();
  });
</script>

<style>
.page-hero { background:linear-gradient(135deg,var(--green-dark),var(--off-black)); border-bottom:1px solid var(--border); padding:60px 48px 48px; }
.page-hero-inner { max-width:1280px; margin:0 auto; }
.page-hero h1 { font-size:clamp(36px,5vw,64px); margin:10px 0 8px; }
.page-hero p  { color:var(--muted); }
.back-link { font-family:var(--font-cond); font-size:13px; font-weight:600; letter-spacing:1px; color:var(--green-bright); text-decoration:none; display:inline-block; margin-bottom:16px; }

.page-inner { max-width:1280px; margin:0 auto; padding:40px 48px; }

.photo-grid { display:grid; grid-template-columns:repeat(auto-fill,minmax(240px,1fr)); gap:6px; }

.photo-cell { position:relative; aspect-ratio:3/2; overflow:hidden; background:var(--card); border:none; cursor:pointer; padding:0; }
.photo-cell img { width:100%; height:100%; object-fit:cover; transition:transform 0.3s; display:block; }
.photo-cell:hover img { transform:scale(1.06); }
.photo-caption { position:absolute; bottom:0; left:0; right:0; background:linear-gradient(to top,rgba(9,12,9,0.85),transparent); color:rgba(238,245,239,0.85); font-size:12px; padding:20px 10px 8px; text-align:center; opacity:0; transition:opacity 0.2s; }
.photo-cell:hover .photo-caption { opacity:1; }

/* LIGHTBOX */
.lightbox { position:fixed; inset:0; background:rgba(5,8,5,0.96); z-index:999; display:flex; align-items:center; justify-content:center; opacity:0; pointer-events:none; transition:opacity 0.2s; }
.lightbox.open { opacity:1; pointer-events:all; }

.lb-img-wrap { max-width:90vw; max-height:90vh; position:relative; }
#lb-img { max-width:90vw; max-height:80vh; object-fit:contain; display:block; border-radius:var(--radius); }
.lb-caption { text-align:center; color:var(--muted); font-size:13px; margin-top:12px; }

.lb-close { position:fixed; top:20px; right:24px; background:none; border:none; color:var(--white); font-size:28px; cursor:pointer; padding:8px; opacity:0.7; transition:opacity 0.15s; }
.lb-close:hover { opacity:1; }
.lb-prev, .lb-next { position:fixed; top:50%; transform:translateY(-50%); background:rgba(255,255,255,0.08); border:1px solid rgba(255,255,255,0.1); border-radius:50%; color:var(--white); font-size:28px; width:48px; height:48px; cursor:pointer; display:flex; align-items:center; justify-content:center; transition:background 0.15s; }
.lb-prev:hover, .lb-next:hover { background:rgba(255,255,255,0.15); }
.lb-prev { left:20px; }
.lb-next { right:20px; }

.empty { color:var(--muted); font-style:italic; padding:40px 0; }
@media (max-width:768px) { .page-hero { padding:40px 20px 32px; } .page-inner { padding:24px 20px; } .lb-prev { left:8px; } .lb-next { right:8px; } }
</style>
